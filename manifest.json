{
  "manifest_version": 3,
  "name": "Farsight Importer",
  "version": "1.0.0",
  "description": "Import characters from D&D Beyond and monsters from Foundry VTT directly into your Farsight app.",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Farsight Importer",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "permissions": [
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "https://*.dndbeyond.com/*",
    "http://*/*",
    "https://*/*"
  ]
}
